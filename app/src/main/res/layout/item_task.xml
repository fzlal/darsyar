<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="48dp"
    android:gravity="center_vertical" android:padding="8dp"
    android:background="#252542" android:layout_marginBottom="4dp">

    <CheckBox android:id="@android:id/checkbox" android:layout_width="32dp"
        android:layout_height="32dp" android:buttonTint="#a78bfa" />

    <TextView android:id="@android:id/text1" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textColor="#f1f5f9" android:textSize="14sp"
        android:layout_marginHorizontal="8dp" />

    <TextView android:id="@android:id/text2" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="11sp"
        android:paddingHorizontal="8dp" android:paddingVertical="2dp" />

    <ImageButton android:id="@android:id/button1" android:layout_width="32dp"
        android:layout_height="32dp" android:src="@android:drawable/ic_menu_delete"
        android:background="@null" android:scaleType="center"
        android:tint="#ef4444" />
</LinearLayout>
