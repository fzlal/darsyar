<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="52dp"
    android:gravity="center_vertical" android:padding="8dp"
    android:background="#252542" android:layout_marginBottom="4dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <View android:id="@android:id/icon" android:layout_width="8dp"
        android:layout_height="8dp" android:background="#10b981"
        android:visibility="gone" android:layout_marginEnd="8dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@android:id/text1" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#f1f5f9"
            android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@android:id/text2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#94a3b8"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView android:id="@+id/durationLabel" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="#6b7280"
        android:textSize="11sp" android:visibility="gone" />
</LinearLayout>
